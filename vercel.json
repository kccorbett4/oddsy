{
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/track-resolve",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/notify-picks",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/hr?action=healthcheck",
      "schedule": "0 14 * * *"
    }
  ]
}
